PORT=4000
FRONTEND_URL=http://localhost:3000

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx    # 911 in production, test number in dev

# Groq
GROQ_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Supabase (for hosting the generated audio file so Twilio can stream it)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=            # use the service role key, not the anon key
SUPABASE_BUCKET=emergency-audio  # create this bucket in Supabase dashboard (public)

# Public URL of this backend — Twilio fetches /api/twiml from here
# Use ngrok in development: ngrok http 4000
PUBLIC_URL=https://your-ngrok-url.ngrok.io
