PORT=4000
FRONTEND_URL=http://localhost:3000

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx    # 911 in production, test number in dev

# Groq
GROQ_API_KEY=

# Supabase — stores call context so /api/respond can look up patient details
# Required table (run in Supabase SQL editor):
#   CREATE TABLE emergency_calls (
#     id UUID PRIMARY KEY,
#     type TEXT NOT NULL,
#     address TEXT NOT NULL,
#     zones TEXT[],
#     age INTEGER,
#     created_at TIMESTAMPTZ DEFAULT NOW()
#   );
SUPABASE_URL=
SUPABASE_SERVICE_KEY=            # use the service role key, not the anon key

# Public URL of this backend — Twilio fetches /api/twiml and posts to /api/respond here
# Use ngrok in development: ngrok http 4000
PUBLIC_URL=https://your-ngrok-url.ngrok.io
